# Snowflake Connection
SNOWFLAKE_ACCOUNT=your_org-your_account
SNOWFLAKE_USER=your_username
#SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_DATABASE=POLYMARKET
SNOWFLAKE_SCHEMA=STREAMING
SNOWFLAKE_WAREHOUSE=INGEST
SNOWFLAKE_ROLE=ACCOUNTADMIN

# Authentication (choose ONE)
# Option 1: Programmatic Access Token (recommended for quick start)
#SNOWFLAKE_PAT=your_programmatic_access_token

# Option 2: Key-Pair JWT (recommended for production)
SNOWFLAKE_PRIVATE_KEY_PATH=/path/to/rsa_key.p8

# Polymarket API
POLYMARKET_API_URL=https://gamma-api.polymarket.com

# React App
NEXT_PUBLIC_SNOWFLAKE_ACCOUNT=your_org-your_account
NEXT_PUBLIC_APP_PORT=4000
